# Dependencies
node_modules/
.pnp
.pnp.js

# Environment variables (NEVER commit these)
.env
.env.local
.env.development
.env.production
.env.*.local

# Build output
dist/
build/

# Uploads (user-generated content)
uploads/
temp/
tmp/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
logs/

# Database dumps & backups (NOT Prisma migrations — those must be tracked)
*.dump
*.sql.gz
backups/*.sql

# Prisma (keep schema AND migrations tracked in git)
# prisma/migrations/ must be committed for production deploys

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# SSL Certificates
*.pem
*.key
*.crt
*.csr

# Sensitive config
secrets/
credentials/

