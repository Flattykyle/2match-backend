@"
# Dependencies
node_modules/
.pnp
.pnp.js

# Environment variables (NEVER commit these)
.env
.env.local
.env.development
.env.production
.env.*.local

# Build output
dist/
build/

# Uploads (user-generated content)
uploads/
temp/
tmp/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
logs/

# Database files (local only)
*.db
*.db-journal
*.sql
*.sql.gz
backups/

# Prisma (keep schema, ignore local migrations)
# Note: Keep migrations/ if you want to track them in git
# Remove this line if you want migrations in git:
# prisma/migrations/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# SSL Certificates
*.pem
*.key
*.crt
*.csr

# Sensitive config
secrets/
credentials/

# Testing
coverage/
"@ | Out-File -FilePath .gitignore -Encoding utf8 -Force