// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// User Model
// ============================================
model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  username String @unique

  // Personal Information
  firstName   String
  lastName    String
  dateOfBirth DateTime
  gender      String

  // Profile Details
  bio       String? @db.Text
  pronouns  String?
  profilePrompts Json?    // [{ question: string, answer: string }]

  locationCity    String?
  locationCountry String?
  latitude        Float?
  longitude       Float?

  lookingFor String

  // Arrays
  profilePictures String[]
  hobbies         String[]
  talents         String[]
  interests       String[]

  preferences Json?

  // Authentication fields
  refreshToken        String?
  refreshTokenExpiry  DateTime?
  resetPasswordToken  String?
  resetPasswordExpiry DateTime?

  // Verification fields
  emailVerified                Boolean   @default(false)
  emailVerificationToken       String?
  emailVerificationExpiry      DateTime?
  phoneNumber                  String?
  phoneVerified                Boolean   @default(false)
  phoneVerificationToken       String?
  photoVerified                Boolean   @default(false)
  photoVerificationStatus      String    @default("pending")
  photoVerificationSubmittedAt DateTime?

  // Voice intro
  voiceIntroUrl      String?
  voiceIntroDuration Int?

  // Subscription & Billing
  subscriptionTier      String    @default("FREE")
  subscriptionExpiresAt DateTime?
  isPremium             Boolean   @default(false)
  premiumExpiresAt      DateTime?
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?
  weeklyBoostsRemaining Int       @default(0)
  lastBoostResetAt      DateTime  @default(now())
  lastBoostedAt         DateTime?

  // Safety / Comfort Zone settings
  slowModeEnabled       Boolean @default(false)
  slowModeLimit         Int     @default(5)
  activeHoursStart      Int?
  activeHoursEnd        Int?
  photoShieldEnabled    Boolean @default(false)
  emergencyContactName  String?
  emergencyContactPhone String?

  // Online status
  isOnline    Boolean   @default(false)
  snoozedUntil DateTime?
  flagged      Boolean   @default(false)

  // Profile extras (v2)
  intention             Intention @default(EXPLORING)
  photoBlurEnabled      Boolean   @default(true)
  redFlag               String?
  greenFlag             String?
  currentlyObsessedWith String?
  spotifyConnected      Boolean   @default(false)
  spotifyAccessToken    String?
  spotifyRefreshToken   String?
  spotifyTokenExpiresAt DateTime?

  // Voice memo (one-to-one)
  voiceMemoId String?    @unique
  voiceMemo   VoiceMemo? @relation(fields: [voiceMemoId], references: [id])

  // Timestamps
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastActive DateTime @default(now())

  // Relations
  matchesAsUser1       Match[]            @relation("User1Matches")
  matchesAsUser2       Match[]            @relation("User2Matches")
  sentMessages         Message[]          @relation("SentMessages")
  receivedMessages     Message[]          @relation("ReceivedMessages")
  conversationsAsUser1 Conversation[]     @relation("User1Conversations")
  conversationsAsUser2 Conversation[]     @relation("User2Conversations")
  likesGiven           Like[]             @relation("LikesGiven")
  likesReceived        Like[]             @relation("LikesReceived")
  passesGiven          Pass[]             @relation("PassesGiven")
  passesReceived       Pass[]             @relation("PassesReceived")
  blocksGiven          Block[]            @relation("BlocksGiven")
  blocksReceived       Block[]            @relation("BlocksReceived")
  profileViewsGiven    ProfileView[]      @relation("ProfileViewsGiven")
  profileViewsReceived ProfileView[]      @relation("ProfileViewsReceived")
  reportsSubmitted     Report[]           @relation("ReportsSubmitted")
  reportsReceived      Report[]           @relation("ReportsReceived")
  icebreakerAnswers    IcebreakerAnswer[]
  userVibeTags         UserVibeTag[]
  promptExchanges      PromptExchange[]
  dateCheckins         DateCheckin[]
  moodCheckins         MoodCheckin[]
  iceBreakerGamesStarted IceBreakerGame[] @relation("IceBreakerGameStarter")

  @@index([email])
  @@index([username])
  @@index([gender])
  @@index([lookingFor])
  @@index([lastActive])
  @@index([latitude, longitude])
  @@index([isOnline])
  @@index([emailVerified])
  @@index([photoVerified])
  @@map("users")
}

// ============================================
// Match Model
// ============================================
model Match {
  id                 String   @id @default(uuid())
  userId1            String
  userId2            String
  compatibilityScore Int
  status             String   @default("pending")
  icebreakerUnlocked Boolean  @default(false)
  slowBurnEnabled    Boolean  @default(false)
  exchangeCount      Float    @default(0)
  chatUnlocked       Boolean  @default(false)
  playlistCreated         Boolean  @default(false)
  aiStarterRegenerations  Int      @default(0)
  matchedAt               DateTime @default(now())

  user1             User               @relation("User1Matches", fields: [userId1], references: [id], onDelete: Cascade)
  user2             User               @relation("User2Matches", fields: [userId2], references: [id], onDelete: Cascade)
  icebreakerAnswers IcebreakerAnswer[]
  promptExchanges   PromptExchange[]
  iceBreakerGame    IceBreakerGame?
  sharedPlaylist    SharedPlaylist?
  dateCheckins      DateCheckin[]

  @@unique([userId1, userId2])
  @@index([userId1])
  @@index([userId2])
  @@index([status])
  @@index([compatibilityScore])
  @@index([matchedAt])
  @@index([userId1, status])
  @@index([userId2, status])
  @@index([userId1, matchedAt])
  @@index([userId2, matchedAt])
  @@map("matches")
}

// ============================================
// Icebreaker Question Model
// ============================================
model IcebreakerQuestion {
  id       String  @id @default(uuid())
  text     String
  options  Json
  category String
  isActive Boolean @default(true)

  answers IcebreakerAnswer[]

  @@index([isActive])
  @@index([category])
  @@map("icebreaker_questions")
}

// ============================================
// Icebreaker Answer Model
// ============================================
model IcebreakerAnswer {
  id         String   @id @default(uuid())
  matchId    String
  userId     String
  questionId String
  answer     String
  answeredAt DateTime @default(now())

  match    Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  question IcebreakerQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId, questionId])
  @@index([matchId])
  @@index([userId])
  @@index([questionId])
  @@map("icebreaker_answers")
}

// ============================================
// Conversation Model
// ============================================
model Conversation {
  id            String    @id @default(uuid())
  user1Id       String
  user2Id       String
  requestStatus String    @default("accepted")
  archived      Boolean   @default(false)
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())

  user1    User      @relation("User1Conversations", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User      @relation("User2Conversations", fields: [user2Id], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@index([lastMessageAt])
  @@index([requestStatus])
  @@map("conversations")
}

// ============================================
// Message Model
// ============================================
model Message {
  id             String    @id @default(uuid())
  senderId       String
  receiverId     String
  conversationId String
  content        String    @db.Text
  type           String    @default("TEXT")
  audioUrl       String?
  audioDuration  Int?
  isRead         Boolean   @default(false)
  readAt         DateTime?
  expiresAt      DateTime?
  isDeleted      Boolean   @default(false)
  sentAt         DateTime  @default(now())

  sender       User              @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver     User              @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  reactions    MessageReaction[]

  @@index([senderId])
  @@index([receiverId])
  @@index([conversationId])
  @@index([isRead])
  @@index([sentAt])
  @@index([expiresAt])
  @@index([isDeleted])
  @@index([conversationId, sentAt])
  @@index([conversationId, isDeleted, sentAt])
  @@index([receiverId, isRead])
  @@index([conversationId, receiverId, isRead])
  @@index([expiresAt, isDeleted])
  @@map("messages")
}

// ============================================
// Message Reaction Model
// ============================================
model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@map("message_reactions")
}

// ============================================
// Like Model
// ============================================
model Like {
  id          String   @id @default(uuid())
  likerId     String
  likedUserId String
  createdAt   DateTime @default(now())

  liker     User @relation("LikesGiven", fields: [likerId], references: [id], onDelete: Cascade)
  likedUser User @relation("LikesReceived", fields: [likedUserId], references: [id], onDelete: Cascade)

  @@unique([likerId, likedUserId])
  @@index([likerId])
  @@index([likedUserId])
  @@index([createdAt])
  @@map("likes")
}

// ============================================
// Pass Model
// ============================================
model Pass {
  id           String   @id @default(uuid())
  passerId     String
  passedUserId String
  createdAt    DateTime @default(now())

  passer     User @relation("PassesGiven", fields: [passerId], references: [id], onDelete: Cascade)
  passedUser User @relation("PassesReceived", fields: [passedUserId], references: [id], onDelete: Cascade)

  @@unique([passerId, passedUserId])
  @@index([passerId])
  @@index([passedUserId])
  @@index([createdAt])
  @@map("passes")
}

// ============================================
// Block Model
// ============================================
model Block {
  id            String   @id @default(uuid())
  blockerId     String
  blockedUserId String
  createdAt     DateTime @default(now())

  blocker     User @relation("BlocksGiven", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedUser User @relation("BlocksReceived", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedUserId])
  @@index([blockerId])
  @@index([blockedUserId])
  @@index([createdAt])
  @@map("blocks")
}

// ============================================
// ProfileView Model
// ============================================
model ProfileView {
  id           String   @id @default(uuid())
  viewerId     String
  viewedUserId String
  viewedAt     DateTime @default(now())

  viewer     User @relation("ProfileViewsGiven", fields: [viewerId], references: [id], onDelete: Cascade)
  viewedUser User @relation("ProfileViewsReceived", fields: [viewedUserId], references: [id], onDelete: Cascade)

  @@index([viewerId])
  @@index([viewedUserId])
  @@index([viewedAt])
  @@map("profile_views")
}

// ============================================
// Report Model
// ============================================
model Report {
  id             String    @id @default(uuid())
  reporterId     String
  reportedUserId String
  reason         String
  description    String?   @db.Text
  status         String    @default("pending")
  reviewedBy     String?
  reviewedAt     DateTime?
  actionTaken    String?
  createdAt      DateTime  @default(now())

  reporter     User @relation("ReportsSubmitted", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser User @relation("ReportsReceived", fields: [reportedUserId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([reportedUserId])
  @@index([status])
  @@index([createdAt])
  @@map("reports")
}

// ============================================
// VibeTag Category Enum
// ============================================
enum VibeTagCategory {
  LIFESTYLE
  PERSONALITY
  INTERESTS
  VALUES
  DATING_STYLE
  HUMOUR
}

// ============================================
// VibeTag Model (M2M with User)
// ============================================
model VibeTag {
  id        String          @id @default(uuid())
  label     String          @unique
  emoji     String
  category  VibeTagCategory
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())

  userVibeTags UserVibeTag[]

  @@index([category])
  @@index([isActive])
  @@map("vibe_tags")
}

// ============================================
// SOS Event Model
// ============================================
model SosEvent {
  id              String   @id @default(uuid())
  userId          String
  latitude        Float?
  longitude       Float?
  notifiedContact String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("sos_events")
}

// ============================================
// New Enums (v2 features)
// ============================================
enum Intention {
  SERIOUS
  CASUAL
  FRIENDS_FIRST
  OPEN
  EXPLORING
}

enum IceBreakerGameType {
  TWO_TRUTHS
  HOT_TAKES
  WOULD_YOU_RATHER
}

enum IceBreakerGameStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum DateCheckinStatus {
  PENDING
  SAFE
  MISSED
}

enum Mood {
  GREAT
  GOOD
  OKAY
  BURNED_OUT
  TAKING_BREAK
}

enum ReportReason {
  INAPPROPRIATE_PHOTOS
  HARASSMENT
  FAKE_PROFILE
  UNSAFE_BEHAVIOR
  HATE_SPEECH
  OTHER
}

// ============================================
// UserVibeTag (explicit join table)
// ============================================
model UserVibeTag {
  userId    String
  vibeTagId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vibeTag VibeTag @relation(fields: [vibeTagId], references: [id], onDelete: Cascade)

  @@id([userId, vibeTagId])
  @@index([userId])
  @@index([vibeTagId])
  @@map("user_vibe_tags")
}

// ============================================
// PromptExchange (Slow Burn mode)
// ============================================
model PromptExchange {
  id        String   @id @default(uuid())
  matchId   String
  senderId  String
  question  String
  answer    String   @db.Text
  createdAt DateTime @default(now())

  match  Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender User  @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([senderId])
  @@index([createdAt])
  @@map("prompt_exchanges")
}

// ============================================
// IceBreakerGame Model
// ============================================
model IceBreakerGame {
  id         String               @id @default(uuid())
  matchId    String               @unique
  gameType   IceBreakerGameType
  status     IceBreakerGameStatus @default(PENDING)
  startedBy  String
  payloadA   Json?
  payloadB   Json?
  guessA     Json?
  guessB     Json?
  result     Json?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  match   Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  starter User  @relation("IceBreakerGameStarter", fields: [startedBy], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("ice_breaker_games")
}

// ============================================
// SharedPlaylist Model
// ============================================
model SharedPlaylist {
  id                     String   @id @default(uuid())
  matchId                String   @unique
  spotifyPlaylistIdUser1 String?
  spotifyPlaylistIdUser2 String?
  tracks                 Json     @default("[]")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("shared_playlists")
}

// ============================================
// DateCheckin (safety check-in)
// ============================================
model DateCheckin {
  id                  String            @id @default(uuid())
  userId              String
  matchId             String?
  scheduledAt         DateTime
  respondedAt         DateTime?
  status              DateCheckinStatus @default(PENDING)
  trustedContactEmail String?
  reminderSentAt      DateTime?
  createdAt           DateTime          @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match? @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([matchId])
  @@index([status])
  @@index([scheduledAt])
  @@map("date_checkins")
}

// ============================================
// MoodCheckin Model
// ============================================
model MoodCheckin {
  id        String   @id @default(uuid())
  userId    String
  mood      Mood
  note      String?  @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mood])
  @@index([createdAt])
  @@map("mood_checkins")
}

// ============================================
// VoiceMemo Model
// ============================================
model VoiceMemo {
  id                 String   @id @default(uuid())
  userId             String   @unique
  cloudinaryPublicId String
  duration           Int
  url                String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User?

  @@index([userId])
  @@map("voice_memos")
}
