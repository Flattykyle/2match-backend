generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                           String             @id @default(uuid())
  email                        String             @unique
  password                     String
  username                     String             @unique
  firstName                    String
  lastName                     String
  dateOfBirth                  DateTime
  gender                       String
  bio                          String?
  locationCity                 String?
  locationCountry              String?
  latitude                     Float?
  longitude                    Float?
  lookingFor                   String
  profilePictures              String[]
  hobbies                      String[]
  talents                      String[]
  interests                    String[]
  preferences                  Json?
  refreshToken                 String?
  refreshTokenExpiry           DateTime?
  resetPasswordToken           String?
  resetPasswordExpiry          DateTime?
  emailVerified                Boolean            @default(false)
  emailVerificationToken       String?
  emailVerificationExpiry      DateTime?
  phoneNumber                  String?
  phoneVerified                Boolean            @default(false)
  phoneVerificationToken       String?
  photoVerified                Boolean            @default(false)
  photoVerificationStatus      String             @default("pending")
  photoVerificationSubmittedAt DateTime?
  isOnline                     Boolean            @default(false)
  createdAt                    DateTime           @default(now())
  updatedAt                    DateTime           @updatedAt
  lastActive                   DateTime           @default(now())
  voiceIntroUrl                String?
  voiceIntroDuration           Int?
  subscriptionTier             String             @default("FREE")
  subscriptionExpiresAt        DateTime?
  stripeCustomerId             String?            @unique
  stripeSubscriptionId         String?
  weeklyBoostsRemaining        Int                @default(0)
  lastBoostResetAt             DateTime           @default(now())
  lastBoostedAt                DateTime?
  slowModeEnabled              Boolean            @default(false)
  slowModeLimit                Int                @default(5)
  activeHoursStart             Int?
  activeHoursEnd               Int?
  photoShieldEnabled           Boolean            @default(false)
  emergencyContactName         String?
  emergencyContactPhone        String?
  currentlyObsessedWith        String?
  greenFlag                    String?
  intention                    Intention          @default(EXPLORING)
  photoBlurEnabled             Boolean            @default(true)
  redFlag                      String?
  spotifyAccessToken           String?
  spotifyConnected             Boolean            @default(false)
  spotifyRefreshToken          String?
  voiceMemoId                  String?            @unique
  profilePrompts               Json?
  pronouns                     String?
  flagged                      Boolean            @default(false)
  isPremium                    Boolean            @default(false)
  premiumExpiresAt             DateTime?
  snoozedUntil                 DateTime?
  spotifyTokenExpiresAt        DateTime?
  blocksReceived               Block[]            @relation("BlocksReceived")
  blocksGiven                  Block[]            @relation("BlocksGiven")
  conversationsAsUser1         Conversation[]     @relation("User1Conversations")
  conversationsAsUser2         Conversation[]     @relation("User2Conversations")
  dateCheckins                 DateCheckin[]
  iceBreakerGamesStarted       IceBreakerGame[]   @relation("IceBreakerGameStarter")
  icebreakerAnswers            IcebreakerAnswer[]
  likesReceived                Like[]             @relation("LikesReceived")
  likesGiven                   Like[]             @relation("LikesGiven")
  matchesAsUser1               Match[]            @relation("User1Matches")
  matchesAsUser2               Match[]            @relation("User2Matches")
  receivedMessages             Message[]          @relation("ReceivedMessages")
  sentMessages                 Message[]          @relation("SentMessages")
  moodCheckins                 MoodCheckin[]
  passesReceived               Pass[]             @relation("PassesReceived")
  passesGiven                  Pass[]             @relation("PassesGiven")
  profileViewsReceived         ProfileView[]      @relation("ProfileViewsReceived")
  profileViewsGiven            ProfileView[]      @relation("ProfileViewsGiven")
  promptExchanges              PromptExchange[]
  reportsReceived              Report[]           @relation("ReportsReceived")
  reportsSubmitted             Report[]           @relation("ReportsSubmitted")
  userVibeTags                 UserVibeTag[]
  voiceMemo                    VoiceMemo?         @relation(fields: [voiceMemoId], references: [id])

  @@index([email])
  @@index([username])
  @@index([gender])
  @@index([lookingFor])
  @@index([lastActive])
  @@index([latitude, longitude])
  @@index([isOnline])
  @@index([emailVerified])
  @@index([photoVerified])
  @@map("users")
}

model Match {
  id                     String             @id @default(uuid())
  userId1                String
  userId2                String
  compatibilityScore     Int
  status                 String             @default("pending")
  matchedAt              DateTime           @default(now())
  icebreakerUnlocked     Boolean            @default(false)
  chatUnlocked           Boolean            @default(false)
  exchangeCount          Float              @default(0)
  playlistCreated        Boolean            @default(false)
  slowBurnEnabled        Boolean            @default(false)
  aiStarterRegenerations Int                @default(0)
  dateCheckins           DateCheckin[]
  iceBreakerGame         IceBreakerGame?
  icebreakerAnswers      IcebreakerAnswer[]
  user1                  User               @relation("User1Matches", fields: [userId1], references: [id], onDelete: Cascade)
  user2                  User               @relation("User2Matches", fields: [userId2], references: [id], onDelete: Cascade)
  promptExchanges        PromptExchange[]
  sharedPlaylist         SharedPlaylist?

  @@unique([userId1, userId2])
  @@index([userId1])
  @@index([userId2])
  @@index([status])
  @@index([compatibilityScore])
  @@index([matchedAt])
  @@index([userId1, status])
  @@index([userId2, status])
  @@index([userId1, matchedAt])
  @@index([userId2, matchedAt])
  @@map("matches")
}

model IcebreakerQuestion {
  id       String             @id @default(uuid())
  text     String
  options  Json
  category String
  isActive Boolean            @default(true)
  answers  IcebreakerAnswer[]

  @@index([isActive])
  @@index([category])
  @@map("icebreaker_questions")
}

model IcebreakerAnswer {
  id         String             @id @default(uuid())
  matchId    String
  userId     String
  questionId String
  answer     String
  answeredAt DateTime           @default(now())
  match      Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  question   IcebreakerQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId, questionId])
  @@index([matchId])
  @@index([userId])
  @@index([questionId])
  @@map("icebreaker_answers")
}

model Conversation {
  id            String    @id @default(uuid())
  user1Id       String
  user2Id       String
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  requestStatus String    @default("accepted")
  archived      Boolean   @default(false)
  user1         User      @relation("User1Conversations", fields: [user1Id], references: [id], onDelete: Cascade)
  user2         User      @relation("User2Conversations", fields: [user2Id], references: [id], onDelete: Cascade)
  messages      Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@index([lastMessageAt])
  @@index([requestStatus])
  @@map("conversations")
}

model Message {
  id             String            @id @default(uuid())
  senderId       String
  receiverId     String
  conversationId String
  content        String
  isRead         Boolean           @default(false)
  sentAt         DateTime          @default(now())
  readAt         DateTime?
  expiresAt      DateTime?
  isDeleted      Boolean           @default(false)
  audioDuration  Int?
  audioUrl       String?
  type           String            @default("TEXT")
  reactions      MessageReaction[]
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  receiver       User              @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender         User              @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([conversationId])
  @@index([isRead])
  @@index([sentAt])
  @@index([expiresAt])
  @@index([isDeleted])
  @@index([conversationId, sentAt])
  @@index([conversationId, isDeleted, sentAt])
  @@index([receiverId, isRead])
  @@index([conversationId, receiverId, isRead])
  @@index([expiresAt, isDeleted])
  @@map("messages")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@map("message_reactions")
}

model Like {
  id          String   @id @default(uuid())
  likerId     String
  likedUserId String
  createdAt   DateTime @default(now())
  likedUser   User     @relation("LikesReceived", fields: [likedUserId], references: [id], onDelete: Cascade)
  liker       User     @relation("LikesGiven", fields: [likerId], references: [id], onDelete: Cascade)

  @@unique([likerId, likedUserId])
  @@index([likerId])
  @@index([likedUserId])
  @@index([createdAt])
  @@map("likes")
}

model Pass {
  id           String   @id @default(uuid())
  passerId     String
  passedUserId String
  createdAt    DateTime @default(now())
  passedUser   User     @relation("PassesReceived", fields: [passedUserId], references: [id], onDelete: Cascade)
  passer       User     @relation("PassesGiven", fields: [passerId], references: [id], onDelete: Cascade)

  @@unique([passerId, passedUserId])
  @@index([passerId])
  @@index([passedUserId])
  @@index([createdAt])
  @@map("passes")
}

model Block {
  id            String   @id @default(uuid())
  blockerId     String
  blockedUserId String
  createdAt     DateTime @default(now())
  blockedUser   User     @relation("BlocksReceived", fields: [blockedUserId], references: [id], onDelete: Cascade)
  blocker       User     @relation("BlocksGiven", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedUserId])
  @@index([blockerId])
  @@index([blockedUserId])
  @@index([createdAt])
  @@map("blocks")
}

model ProfileView {
  id           String   @id @default(uuid())
  viewerId     String
  viewedUserId String
  viewedAt     DateTime @default(now())
  viewedUser   User     @relation("ProfileViewsReceived", fields: [viewedUserId], references: [id], onDelete: Cascade)
  viewer       User     @relation("ProfileViewsGiven", fields: [viewerId], references: [id], onDelete: Cascade)

  @@index([viewerId])
  @@index([viewedUserId])
  @@index([viewedAt])
  @@map("profile_views")
}

model Report {
  id             String    @id @default(uuid())
  reporterId     String
  reportedUserId String
  reason         String
  description    String?
  status         String    @default("pending")
  reviewedBy     String?
  reviewedAt     DateTime?
  actionTaken    String?
  createdAt      DateTime  @default(now())
  reportedUser   User      @relation("ReportsReceived", fields: [reportedUserId], references: [id], onDelete: Cascade)
  reporter       User      @relation("ReportsSubmitted", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([reportedUserId])
  @@index([status])
  @@index([createdAt])
  @@map("reports")
}

model VibeTag {
  id           String          @id @default(uuid())
  label        String          @unique
  emoji        String
  category     VibeTagCategory
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  userVibeTags UserVibeTag[]

  @@index([category])
  @@index([isActive])
  @@map("vibe_tags")
}

model SosEvent {
  id              String   @id @default(uuid())
  userId          String
  latitude        Float?
  longitude       Float?
  notifiedContact String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("sos_events")
}

model UserVibeTag {
  userId    String
  vibeTagId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vibeTag   VibeTag @relation(fields: [vibeTagId], references: [id], onDelete: Cascade)

  @@id([userId, vibeTagId])
  @@index([userId])
  @@index([vibeTagId])
  @@map("user_vibe_tags")
}

model PromptExchange {
  id        String   @id @default(uuid())
  matchId   String
  senderId  String
  question  String
  answer    String
  createdAt DateTime @default(now())
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([senderId])
  @@index([createdAt])
  @@map("prompt_exchanges")
}

model IceBreakerGame {
  id        String               @id @default(uuid())
  matchId   String               @unique
  gameType  IceBreakerGameType
  status    IceBreakerGameStatus @default(PENDING)
  payloadA  Json?
  payloadB  Json?
  result    Json?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  startedBy String
  guessA    Json?
  guessB    Json?
  match     Match                @relation(fields: [matchId], references: [id], onDelete: Cascade)
  starter   User                 @relation("IceBreakerGameStarter", fields: [startedBy], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("ice_breaker_games")
}

model SharedPlaylist {
  id                     String   @id @default(uuid())
  matchId                String   @unique
  tracks                 Json     @default("[]")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  spotifyPlaylistIdUser1 String?
  spotifyPlaylistIdUser2 String?
  match                  Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("shared_playlists")
}

model DateCheckin {
  id                  String            @id @default(uuid())
  userId              String
  matchId             String?
  scheduledAt         DateTime
  respondedAt         DateTime?
  status              DateCheckinStatus @default(PENDING)
  trustedContactEmail String?
  createdAt           DateTime          @default(now())
  reminderSentAt      DateTime?
  match               Match?            @relation(fields: [matchId], references: [id])
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([matchId])
  @@index([status])
  @@index([scheduledAt])
  @@map("date_checkins")
}

model MoodCheckin {
  id        String   @id @default(uuid())
  userId    String
  mood      Mood
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mood])
  @@index([createdAt])
  @@map("mood_checkins")
}

model VoiceMemo {
  id                 String   @id @default(uuid())
  userId             String   @unique
  cloudinaryPublicId String
  duration           Int
  url                String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User?

  @@index([userId])
  @@map("voice_memos")
}

enum VibeTagCategory {
  LIFESTYLE
  PERSONALITY
  INTERESTS
  VALUES
  DATING_STYLE
  HUMOUR
}

enum Intention {
  SERIOUS
  CASUAL
  FRIENDS_FIRST
  OPEN
  EXPLORING
}

enum IceBreakerGameType {
  TWO_TRUTHS
  HOT_TAKES
  WOULD_YOU_RATHER
}

enum IceBreakerGameStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum DateCheckinStatus {
  PENDING
  SAFE
  MISSED
}

enum Mood {
  GREAT
  GOOD
  OKAY
  BURNED_OUT
  TAKING_BREAK
}

enum ReportReason {
  INAPPROPRIATE_PHOTOS
  HARASSMENT
  FAKE_PROFILE
  UNSAFE_BEHAVIOR
  HATE_SPEECH
  OTHER
}
