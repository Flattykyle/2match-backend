# ===========================================
# 2-Match Backend Environment Variables
# ===========================================

# Server Configuration
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/2match?schema=public"

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Redis (Optional - for caching and sessions)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# Sentry (Error Tracking - Optional)
SENTRY_DSN=your-sentry-dsn-url
ENABLE_CONSOLE_LOGS=true

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Service (for verification emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@2match.com

# SMS Service (for phone verification - Optional)
# Twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Or AWS SNS
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# Frontend URL (for email links and CORS)
FRONTEND_URL=http://localhost:5173

# Session Configuration
SESSION_SECRET=your-session-secret-key-change-this-in-production

# File Upload Limits
MAX_FILE_SIZE=10485760
MAX_PHOTOS_PER_USER=6

# Security
BCRYPT_ROUNDS=10

# Feature Flags (Optional)
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PHONE_VERIFICATION=true
ENABLE_PHOTO_VERIFICATION=true
ENABLE_REDIS_CACHE=true

# Mapbox (for location features)
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token

# Admin Configuration
ADMIN_EMAIL=admin@2match.com
ADMIN_PASSWORD=change-this-secure-password

# ===========================================
# Production-only variables (add these in production)
# ===========================================

# Database (Production)
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public&sslmode=require"

# CORS (Production - comma-separated for multiple origins)
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Sentry (Production)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Redis (Production - if using hosted Redis)
# REDIS_URL=rediss://username:password@host:port

# Email (Production)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key

# ===========================================
# Notes:
# ===========================================
# 1. Never commit the actual .env file to version control
# 2. Generate strong JWT secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 3. For production, use environment variables from your hosting platform
# 4. Enable HTTPS in production (handled by hosting platform)
# 5. Set NODE_ENV=production in production environment
