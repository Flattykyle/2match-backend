# ===========================================
# 2-Match Backend - Production Environment
# ===========================================
# Use this as a template for your production deployment
# Configure these in your hosting platform (Railway/Render/etc.)

# ===========================================
# REQUIRED - Server Configuration
# ===========================================
NODE_ENV=production
PORT=3001

# ===========================================
# REQUIRED - Database (PostgreSQL)
# ===========================================
# Supabase: Get from Project Settings > Database > Connection String (URI)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/database?schema=public&sslmode=require

# ===========================================
# REQUIRED - JWT Authentication
# ===========================================
# Generate strong secrets using:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-production-jwt-secret-min-64-chars-super-secure
JWT_REFRESH_SECRET=your-production-refresh-secret-min-64-chars-different-from-jwt
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d

# ===========================================
# REQUIRED - CORS Configuration
# ===========================================
# Your Vercel/Netlify frontend URL (comma-separated for multiple)
CORS_ORIGIN=https://your-app.vercel.app,https://www.your-domain.com
CORS_CREDENTIALS=true

# ===========================================
# REQUIRED - Cloudinary (Image Upload)
# ===========================================
# Get credentials from: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=your-production-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ===========================================
# REQUIRED - Frontend URL
# ===========================================
# Used for CORS and email links
FRONTEND_URL=https://your-app.vercel.app

# ===========================================
# OPTIONAL - Redis (Recommended for production)
# ===========================================
# Upstash Redis: Get from https://upstash.com/
# Format: rediss://default:[password]@[host]:[port]
# REDIS_URL=rediss://default:password@host:port
# REDIS_HOST=your-redis-host.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_DB=0
# REDIS_TTL=3600
# ENABLE_REDIS_CACHE=true

# If Redis is not available, set to false
ENABLE_REDIS_CACHE=false

# ===========================================
# OPTIONAL - Sentry (Error Tracking)
# ===========================================
# Get DSN from: https://sentry.io/settings/projects/
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
ENABLE_CONSOLE_LOGS=false

# ===========================================
# OPTIONAL - Logging
# ===========================================
LOG_LEVEL=error

# ===========================================
# OPTIONAL - Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# OPTIONAL - Email Service
# ===========================================
# For production, use SendGrid or similar
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
# EMAIL_FROM=noreply@yourdomain.com

# ===========================================
# OPTIONAL - Stripe (Billing & Subscriptions)
# ===========================================
# Get credentials from: https://dashboard.stripe.com/apikeys
# Server will start without these but billing endpoints return 503
# STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
# STRIPE_PREMIUM_PRICE_ID=price_xxx
# STRIPE_PLATINUM_PRICE_ID=price_xxx

# ===========================================
# OPTIONAL - Mapbox
# ===========================================
# Get token from: https://account.mapbox.com/access-tokens/
# MAPBOX_ACCESS_TOKEN=sk.your-mapbox-secret-token

# ===========================================
# OPTIONAL - Session Configuration
# ===========================================
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-production-session-secret-min-32-chars

# ===========================================
# File Upload Limits
# ===========================================
MAX_FILE_SIZE=10485760
MAX_PHOTOS_PER_USER=6

# ===========================================
# Security
# ===========================================
BCRYPT_ROUNDS=12

# ===========================================
# Feature Flags
# ===========================================
ENABLE_EMAIL_VERIFICATION=false
ENABLE_PHONE_VERIFICATION=false
ENABLE_PHOTO_VERIFICATION=true

# ===========================================
# PRODUCTION DEPLOYMENT NOTES:
# ===========================================
#
# 1. NEVER commit actual .env file to git
# 2. Configure these in your hosting platform's dashboard
# 3. Use strong, unique secrets (minimum 32 characters)
# 4. Enable HTTPS (automatic on Railway/Render/Vercel)
# 5. Test all endpoints after deployment
# 6. Monitor logs and errors via Sentry
# 7. Set up database backups (Supabase does this automatically)
# 8. Use environment-specific values (don't reuse dev credentials)
#
# ===========================================
